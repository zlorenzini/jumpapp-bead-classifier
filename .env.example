# -----------------------------------------------------------------------
# Bead Classifier JumpApp – Environment Variables
# Copy this file to .env and fill in your values.
# -----------------------------------------------------------------------

# MongoDB connection
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bead_classifier

# Shopify Admin API (private app token)
# Create a private app in your Shopify admin under Apps → Develop apps
SHOPIFY_STORE=my-store.myshopify.com
SHOPIFY_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-01

# Inference tuning
CONFIDENCE_THRESHOLD=0.65   # minimum cosine similarity to report a match
TOP_K=5                     # maximum number of matches returned per image

# Server binding
HOST=127.0.0.1
PORT=8000

# -----------------------------------------------------------------------
# Web acquisition  (POST /acquire)
# Provide ONE search provider + OpenAI to enable automatic web ingestion.
# SerpAPI takes priority over Google CSE when both keys are present.
# -----------------------------------------------------------------------

# Option A — SerpAPI (https://serpapi.com/)  free tier: 100 searches/month
# SERPAPI_KEY=

# Option B — Google Custom Search Engine
#   1. Enable "Custom Search API" in Google Cloud Console
#   2. Create a Programmable Search Engine at https://cse.google.com
#      and set it to search the whole web with Image Search enabled
# GOOGLE_API_KEY=
# GOOGLE_CX=

# OpenAI — LLM metadata extractor  (any JSON-capable model works)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
