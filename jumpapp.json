{
  "name": "jumpapp-bead-classifier",
  "version": "1.0.0",
  "description": "Portable bead classifier using ResNet-50 embeddings",

  "storage": {
    "models": "models",
    "dataset": "dataset",
    "endpoints": "endpoints"
  },

  "models": {
    "embedder": "resnet50",
    "embedding_dim": 2048
  },

  "capabilities": {
    "requires": [
      "camera",
      "filesystem",
      "network"
    ]
  },

  "endpoints": {
    "add-bead": "/add-bead",
    "train": "/train",
    "bundles": "/bundles",
    "infer": "/infer",
    "capture": "/capture"
  }
}

