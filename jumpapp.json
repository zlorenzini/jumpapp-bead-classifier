{
  "name": "jumpapp-bead-classifier",
  "version": "1.0.0",
  "description": "Analyzes product photos to identify bead types and updates Shopify product tags via the Admin API.",

  "entrypoint": "server/main.py",
  "ui": "ui/index.html",

  "capabilities": {
    "requires": [
      "mongodb",
      "shopify_admin_api"
    ]
  },

  "endpoints": {
    "status": "/status",
    "infer": "/infer",
    "train": "/train",
    "beads": "/beads",
    "shopify_tag": "/shopify/tag"
  },

  "models": {
    "default": null,
    "embedder": "resnet50",
    "embedding_dim": 2048
  },

  "dataset": {
    "type": "datalake",
    "labels": "dataset/labels.json"
  },

  "storage": {
    "comment": "All paths are relative to the directory containing this jumpapp.json file.",
    "root": ".",
    "endpoints": "endpoints",
    "models": "models",
    "dataset": "dataset"
  },

  "portable": true
}

